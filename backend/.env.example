# Salin file ini menjadi .env lalu sesuaikan nilainya.

# URL database SQLAlchemy. Default: SQLite lokal (tidak perlu setup apa pun).
# Untuk PostgreSQL: postgresql://user:password@localhost:5432/seapedia
DATABASE_URL=sqlite:///./seapedia.db

# Secret untuk menandatangani JWT. WAJIB diganti di production.
JWT_SECRET=ganti-dengan-string-acak-yang-panjang

# Masa berlaku token dalam jam.
TOKEN_EXPIRE_HOURS=24

# Origin frontend yang diizinkan CORS (pisahkan dengan koma).
CORS_ORIGINS=http://localhost:5173
